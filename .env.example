SOLANA_RPC_URL=http://127.0.0.1:8899
ANCHOR_WALLET=/Users/your-user/.config/solana/id.json
ESCROW_PROGRAM_ID=CTRDkdc7fN427u2p3gVHJvosy2GihnRwer5T6CM98xtH
DEVNET_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
BUYER_KEYPAIR_PATH=/Users/your-user/.config/solana/id.json
SELLER_KEYPAIR_PATH=/Users/your-user/.config/solana/x402-seller.json
HONEST_SERVER_URL=http://127.0.0.1:8788
MALICIOUS_SERVER_URL=http://127.0.0.1:8789
FACILITATOR_URL=https://www.x402.org/facilitator
X402_SOLANA_NETWORK=solana-devnet
NEXT_PUBLIC_DEMO_API_BASE=http://127.0.0.1:8787
MIDDLEWARE_PORT=8787
DIRECT_X402_PRICE_USD=0.05
RUN_STORE_BACKEND=firestore
FIRESTORE_RUN_COLLECTION=kova_demo_runs

# Cloud Run deployment: pass keypair bytes as JSON instead of a file path.
# Exactly one of *_PATH or *_JSON must be set for each keypair.
# BUYER_KEYPAIR_JSON=[1,2,3,...]
# SELLER_KEYPAIR_JSON=[1,2,3,...]

# Public backend demo mode. Set to "false" for real devnet settlement.
# SIMULATE_PUBLIC_DEMO=false

# Optional Firestore override if you do not want the default database.
# FIRESTORE_DATABASE_ID=(default)

# Optional Vercel fallback storage if you still deploy the backend there.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
# RUN_STORE_PREFIX=kova:demo-runs
# RUN_STORE_MAX=100
