# Serverless / Vercel deployment: pass keypair bytes as JSON instead of a file path.
# Exactly one of *_PATH or *_JSON must be set for each keypair.
# BUYER_KEYPAIR_JSON=[1,2,3,...]
# SELLER_KEYPAIR_JSON=[1,2,3,...]

# Set to "true" to run demo scenarios synchronously (required on serverless platforms
# where background work is killed after the response is sent).
# SYNC_DEMO_RUNS=false
